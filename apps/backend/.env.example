# Google Play Billing — Android subscription verification
# 1. In Google Play Console → Setup → API access, link a Google Cloud project
# 2. Create a service account, grant it "View financial data, orders, and cancellation survey responses"
# 3. Download the JSON key, paste the entire contents as a single line below
GOOGLE_PLAY_PACKAGE_NAME=com.zenfit.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
